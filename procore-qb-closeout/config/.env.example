# ============================================================
# PROCORE-QB CLOSEOUT CLI CONFIGURATION
# ============================================================
# Copy this file to .env and fill in your credentials
#
# IMPORTANT: The CLI tool uses these credentials.
# The web dashboard does NOT need these - it reads from Supabase.
# ============================================================

# ------------------------------------------------------------
# PROCORE API CONFIGURATION
# ------------------------------------------------------------
# Get these from: https://developers.procore.com/
# 1. Create an app in the Procore Developer Portal
# 2. Set up OAuth 2.0 with authorization code grant
# 3. Use the OAuth flow to get access/refresh tokens

PROCORE_CLIENT_ID=your_procore_client_id
PROCORE_CLIENT_SECRET=your_procore_client_secret
PROCORE_ACCESS_TOKEN=your_procore_access_token
PROCORE_REFRESH_TOKEN=your_procore_refresh_token
PROCORE_COMPANY_ID=your_procore_company_id

# ------------------------------------------------------------
# QUICKBOOKS ONLINE API CONFIGURATION
# ------------------------------------------------------------
# Get these from: https://developer.intuit.com/
# 1. Create an app in the Intuit Developer Portal
# 2. Select QuickBooks Online Accounting API
# 3. Set up OAuth 2.0 and get tokens
# 4. The Realm ID is your QuickBooks company ID

QBO_CLIENT_ID=your_qbo_client_id
QBO_CLIENT_SECRET=your_qbo_client_secret
QBO_ACCESS_TOKEN=your_qbo_access_token
QBO_REFRESH_TOKEN=your_qbo_refresh_token
QBO_REALM_ID=your_qbo_realm_id

# ------------------------------------------------------------
# ANTHROPIC API CONFIGURATION (for AI features)
# ------------------------------------------------------------
# Get from: https://console.anthropic.com/
# Optional - AI analysis will be skipped if not provided

ANTHROPIC_API_KEY=your_anthropic_api_key

# ------------------------------------------------------------
# APPLICATION SETTINGS (optional)
# ------------------------------------------------------------
LOG_LEVEL=INFO
RATE_LIMIT_RETRY_COUNT=3
RATE_LIMIT_BACKOFF_BASE=2
