# ============================================================
# WEB DASHBOARD CONFIGURATION
# ============================================================
# Set these in Netlify: Site settings > Environment variables
# ============================================================

# ------------------------------------------------------------
# SUPABASE CONFIGURATION (Required)
# ------------------------------------------------------------
# Get these from your Supabase project:
#   Project Settings > API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# For serverless functions (use service role key for write access)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# ------------------------------------------------------------
# PROCORE OAUTH CONFIGURATION (Required for OAuth flow)
# ------------------------------------------------------------
# Get these from: https://developers.procore.com/
# 1. Create an app in the Procore Developer Portal
# 2. Add OAuth redirect URI: https://your-site.netlify.app/.netlify/functions/oauth-callback?provider=procore

# Client ID for frontend OAuth redirect
VITE_PROCORE_CLIENT_ID=your_procore_client_id

# Server-side OAuth credentials (for serverless functions)
PROCORE_CLIENT_ID=your_procore_client_id
PROCORE_CLIENT_SECRET=your_procore_client_secret

# ------------------------------------------------------------
# QUICKBOOKS ONLINE OAUTH CONFIGURATION (Required for OAuth flow)
# ------------------------------------------------------------
# Get these from: https://developer.intuit.com/
# 1. Create an app in the Intuit Developer Portal
# 2. Add OAuth redirect URI: https://your-site.netlify.app/.netlify/functions/oauth-callback?provider=quickbooks

# Client ID for frontend OAuth redirect
VITE_QBO_CLIENT_ID=your_qbo_client_id

# Server-side OAuth credentials (for serverless functions)
QBO_CLIENT_ID=your_qbo_client_id
QBO_CLIENT_SECRET=your_qbo_client_secret

# ------------------------------------------------------------
# ANTHROPIC API (Optional - for AI analysis)
# ------------------------------------------------------------
# Get from: https://console.anthropic.com/
# AI analysis will be skipped if not provided
ANTHROPIC_API_KEY=your_anthropic_api_key
